# Required for cloud sync. On Vercel, add both under Project → Settings → Environment Variables
# (names must start with VITE_ or they will not exist in the browser build).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# OAuth redirect base (defaults to window.location.origin in app if unset)
VITE_SITE_URL=http://localhost:5173
